digraph "OPC_UA_Final_State_Machine" {
    rankdir=LR;
    bgcolor="white";
    fontname="Arial";
    node [fontname="Arial", fontsize=12,
          style=filled, shape=circle,
          width=1.8, height=1.8];
    edge [fontname="Arial", fontsize=9];

    __start [shape=none, label="", width=0, height=0];
    __start -> s0 [label="start"];

    s0 [label="s0\nDisconnected", fillcolor="#FFD54F", color="#F57F17", penwidth=2];
    s1 [label="s1\nConnected", fillcolor="#4FC3F7", color="#0277BD", penwidth=2];
    s2 [label="s2\nConnected\n+Subscribed", fillcolor="#80DEEA", color="#00838F", penwidth=2];

    s0 -> s1 [label="CONNECT/CONNECT_OK", color="#2E7D32", fontcolor="#2E7D32", style="solid", penwidth=2.0];
    s0 -> s0 [label="DISCONNECT/NOT_CONNECTED\nREAD/NOT_CONNECTED\nWRITE/NOT_CONNECTED\nBROWSE/NOT_CONNECTED\nCREATE_SUB/NOT_CONNECTED\nDELETE_SUB/NOT_CONNECTED", color="#C62828", fontcolor="#C62828", style="dashed", penwidth=1.5];
    s1 -> s1 [label="CONNECT/ALREADY_CONNECTED\nREAD/READ_OK\nWRITE/WRITE_REJECTED\nBROWSE/BROWSE_OK\nDELETE_SUB/NO_SUB", color="#BF360C", fontcolor="#BF360C", style="dashed", penwidth=1.5];
    s1 -> s0 [label="DISCONNECT/DISCONNECT_OK", color="#1565C0", fontcolor="#1565C0", style="solid", penwidth=2.0];
    s1 -> s2 [label="CREATE_SUB/CREATE_SUB_OK", color="#00695C", fontcolor="#00695C", style="solid", penwidth=2.0];
    s2 -> s2 [label="CONNECT/ALREADY_CONNECTED\nREAD/READ_OK\nWRITE/WRITE_REJECTED\nBROWSE/BROWSE_OK\nCREATE_SUB/SUB_EXISTS", color="#BF360C", fontcolor="#BF360C", style="dashed", penwidth=1.5];
    s2 -> s0 [label="DISCONNECT/DISCONNECT_OK", color="#1565C0", fontcolor="#1565C0", style="solid", penwidth=2.0];
    s2 -> s1 [label="DELETE_SUB/DELETE_SUB_OK", color="#4527A0", fontcolor="#4527A0", style="solid", penwidth=2.0];
}